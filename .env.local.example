# Base URL for canonical links and OG tags (e.g. https://eternalmemory.app)
# For local dev use http://localhost:3000 (or your dev port)
NEXT_PUBLIC_APP_URL=http://localhost:3001

# Resend (email transazionali — solo server, mai NEXT_PUBLIC_*)
# Dashboard: https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxx
# Dominio verificato su Resend, es. EternalMemory <noreply@tuodominio.com>
# In test puoi ometterla e usare onboarding@resend.dev (solo verso email del tuo account Resend)
EMAIL_FROM=EternalMemory <noreply@tuodominio.com>

# Stripe B2B subscription (separate from one-off tribute checkout)
# Product: recurring monthly in Stripe Dashboard → copy Price ID
STRIPE_B2B_PRICE_ID=price_xxxxxxxx
# Webhook endpoint: /api/stripe/b2b-webhook (dedicated secret, not the tribute webhook)
STRIPE_B2B_WEBHOOK_SECRET=whsec_xxxxxxxx
