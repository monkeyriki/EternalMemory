# Optional: comma-separated IPs that never get IP-ban checks (e.g. your home IP if you lock yourself out before login).
# Logged-in platform admins are always exempt from bans; this is for recovery / non-admin staff IPs.
# IP_BAN_EXEMPT_IPS=203.0.113.50,198.51.100.2

# Base URL for canonical links, Stripe redirects, and emails (production must be https://)
# For local dev use http://localhost:3000 (or your dev port). TLS is enforced by your host in production.
NEXT_PUBLIC_APP_URL=http://localhost:3001

# Privacy & data-rights inbox (GDPR/CCPA) — shown on /privacy, /contact, /account/delete
# NEXT_PUBLIC_PRIVACY_EMAIL=privacy@yourdomain.com

# Signed httpOnly cookie after memorial password unlock (tributes + Stripe checkout on password pages).
# Required in production (min 16 characters). Generate: openssl rand -hex 32
MEMORIAL_GATE_SECRET=

# Resend (email transazionali — solo server, mai NEXT_PUBLIC_*)
# Dashboard: https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxx
# Dominio verificato su Resend, es. EternalMemory <noreply@tuodominio.com>
# In test puoi ometterla e usare onboarding@resend.dev (solo verso email del tuo account Resend)
EMAIL_FROM=EternalMemory <noreply@tuodominio.com>

# Stripe B2B subscription (separate from one-off tribute checkout)
# Product: recurring monthly in Stripe Dashboard → copy Price ID
STRIPE_B2B_PRICE_ID=price_xxxxxxxx
# Webhook endpoint: /api/stripe/b2b-webhook (dedicated secret, not the tribute webhook)
STRIPE_B2B_WEBHOOK_SECRET=whsec_xxxxxxxx

# Consumer memorial hosting (Checkout + main /api/stripe/webhook)
# Required for "Buy lifetime" / Premium subscribe: create Products → Prices in Stripe Dashboard, copy each price_… ID.
# In Vercel: Project → Settings → Environment Variables → add all three for Production (and Preview if needed).
STRIPE_PRICE_MEMORIAL_PREMIUM_MONTHLY=price_xxxxxxxx
STRIPE_PRICE_MEMORIAL_PREMIUM_YEARLY=price_xxxxxxxx
# One-time payment mode — must be a one-time Price in Stripe (not recurring)
STRIPE_PRICE_MEMORIAL_LIFETIME=price_xxxxxxxx
# Legacy alias (same value as above) — still read by the app if the canonical name is unset
# STRIPE_PRICE_MEMORIAL_PREMIUM_LIFETIME=price_xxxxxxxx
# Same webhook as virtual tributes: add events checkout.session.completed, customer.subscription.updated, customer.subscription.deleted
# STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxx
